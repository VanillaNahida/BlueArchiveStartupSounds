<Window x:Class="BlueArchiveStartupSounds.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="关于" Height="437" Width="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="0,0,0,-6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Image Source="pack://application:,,,/AppIcon.ico" Width="100" Height="100" Margin="0,0,0,10"/>
            <TextBlock Text="蔚蓝档案开机音效" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock FontSize="12" HorizontalAlignment="Center" Margin="0,5,0,0" TextWrapping="Wrap" Width="300" TextAlignment="Center"><Run Text="一个快捷设置蔚蓝档案开机音效和动画的小程序，使用C#编写"/><Run Text="。"/><LineBreak/><Run Language="zh-cn" Text="粉丝群：1074471035"/><LineBreak/><Hyperlink NavigateUri="https://www.xcnahida.cn/?p=PExbbSq8" RequestNavigate="Hyperlink_RequestNavigate">点我跳转到群列表</Hyperlink><Run/></TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="20,20,20,0" VerticalAlignment="Top">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="软件作者:" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBlock Text="香草味的纳西妲喵（VanillaNahida）" Grid.Column="1" VerticalAlignment="Center"/>
            </Grid>
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="软件版本:" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBlock Text="1.0.0" Grid.Column="1" VerticalAlignment="Center"/>
            </Grid>
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="GitHub:" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" TextWrapping="Wrap" Width="250">
                    <Hyperlink NavigateUri="https://github.com/VanillaNahida/BlueArchiveStartupSounds" RequestNavigate="Hyperlink_RequestNavigate">
                        https://github.com/VanillaNahida/BlueArchiveStartupSounds
                    </Hyperlink>
                </TextBlock>
            </Grid>
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="哔哩哔哩:" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" TextWrapping="Wrap" Width="250">
                    <Hyperlink NavigateUri="https://space.bilibili.com/1347891621" RequestNavigate="Hyperlink_RequestNavigate">
                        https://space.bilibili.com/1347891621
                    </Hyperlink>
                </TextBlock>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,0,0,20">
            <Button Content="确定" Width="80" Height="30" Click="OkButton_Click"/>
        </StackPanel>
    </Grid>
</Window>